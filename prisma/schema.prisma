generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SITE_MANAGER
  VIEWER
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

enum AlertCategory {
  HVAC
  WATER
  LIGHTING
  BOILER
  OCCUPANCY
  TARIFF
  MAINTENANCE
  SCHEDULING
}

enum AlertStatus {
  OPEN
  AGENT_ACTING
  HUMAN_REVIEW
  RESOLVED
  DISMISSED
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  OVERRIDDEN
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String
  password   String
  role       Role      @default(VIEWER)
  siteAccess Site[]    @relation("UserSiteAccess")
  sessions   Session[]
  createdAt  DateTime  @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Sites ──────────────────────────────────────────────────────────────────

model Site {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  city           String
  rooms          Int
  totalSqm       Int
  floors         Int
  yearBuilt      Int
  energyRating   String
  hvacType       String
  solarPanels    Boolean         @default(false)
  smartMeters    Boolean         @default(true)
  readings       EnergyReading[]
  alerts         Alert[]
  agentActions   AgentAction[]
  agentConfig    AgentConfig?
  savingsRecords SavingsRecord[]
  users          User[]          @relation("UserSiteAccess")
}

// ─── Energy ─────────────────────────────────────────────────────────────────

model EnergyReading {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  timestamp       DateTime
  intervalMinutes Int      @default(30)
  hvacKwh         Float
  waterKwh        Float
  lightingKwh     Float
  communalKwh     Float
  otherKwh        Float
  totalKwh        Float
  optimisedKwh    Float
  savingsKwh      Float
  costGbp         Float
  savingsGbp      Float
  tariffRate      Float
  occupancyRate   Float
  outsideTemp     Float
  co2Kg           Float

  @@index([siteId, timestamp])
}

// ─── Alerts ─────────────────────────────────────────────────────────────────

model Alert {
  id              String      @id @default(cuid())
  siteId          String
  site            Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  severity        Severity
  category        AlertCategory
  title           String
  message         String
  estimatedSaving Float
  status          AlertStatus @default(OPEN)
  agentAction     String?
  agentActedAt    DateTime?
  humanReviewedBy String?
  humanReviewedAt DateTime?
  createdAt       DateTime    @default(now())
  resolvedAt      DateTime?
}

// ─── Agent Actions ──────────────────────────────────────────────────────────

model AgentAction {
  id              String        @id @default(cuid())
  siteId          String
  site            Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category        AlertCategory
  description     String
  reasoning       String
  actionTaken     String
  autonomous      Boolean       @default(true)
  estimatedSaving Float
  confirmedSaving Float?
  status          ActionStatus  @default(PENDING)
  createdAt       DateTime      @default(now())
  completedAt     DateTime?
}

// ─── Savings ────────────────────────────────────────────────────────────────

model SavingsRecord {
  id           String        @id @default(cuid())
  siteId       String
  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  month        String
  category     AlertCategory
  projectedGbp Float
  actualGbp    Float
  co2SavedKg   Float
}

// ─── Agent Config ───────────────────────────────────────────────────────────

model AgentConfig {
  id                  String  @id @default(cuid())
  siteId              String  @unique
  site                Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  hvacAutoSchedule    Boolean @default(true)
  voidRoomDetection   Boolean @default(true)
  peakAvoidance       Boolean @default(true)
  lightingAutomation  Boolean @default(true)
  boilerOptimisation  Boolean @default(true)
  waterHeatingOpt     Boolean @default(true)
  maxAutonomyLevel    Int     @default(3)
  hvacMinTemp         Float   @default(18.0)
  hvacMaxTemp         Float   @default(22.0)
  nightModeStart      String  @default("23:00")
  nightModeEnd        String  @default("06:00")
  peakTariffThreshold Float   @default(0.35)
}

// ─── Platform Settings (singleton) ──────────────────────────────────────────

model PlatformSettings {
  id              String   @id @default("platform")
  agentActive     Boolean  @default(true)
  globalAutonomy  Int      @default(3)
  updatedAt       DateTime @updatedAt
}

// ─── Notification Preferences (singleton) ───────────────────────────────────

model NotificationPreferences {
  id              String   @id @default("notifications")
  alertLevel      String   @default("CRITICAL")
  recipientEmails String   @default("[]")
  dailyDigest     Boolean  @default(false)
  dailyDigestTime String   @default("08:00")
  weeklyReport    Boolean  @default(true)
  weeklyReportDay String   @default("MONDAY")
  updatedAt       DateTime @updatedAt
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  userName      String
  action        String
  entity        String
  entityId      String?
  previousValue String
  newValue      String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}
